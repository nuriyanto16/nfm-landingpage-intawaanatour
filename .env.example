# =====================================================================
#  Variabel untuk docker-compose (root). Dibaca otomatis oleh
#  `docker compose up`. Salin ke `.env` LALU isi sesuai lingkungan.
#
#  - Lokal (dev): TIDAK perlu file ini; default di docker-compose.yml
#    sudah development + http://localhost:8082/.
#  - VPS (produksi): buat file `.env` di folder yang sama dengan
#    docker-compose.yml, isi seperti di bawah, lalu `docker compose up -d`.
# =====================================================================

# Mode aplikasi: production menyembunyikan error & mengaktifkan cache.
CI_ENVIRONMENT=production

# WAJIB lengkap: skema https + host + sub-path + slash di akhir.
# Tanpa ini, redirect /admin -> /admin/login kehilangan prefix dan
# turun ke http (mis. http://nfmtech.my.id/admin) di balik nginx.
APP_BASE_URL=https://nfmtech.my.id/landingpage/intawaantour/
